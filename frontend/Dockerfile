# ─────────────────────────────────────────────────────────────────────────────
# DentalOS Frontend — Multi-stage Dockerfile (Next.js 16 standalone)
#
# Stage 1 (deps):    Install all npm dependencies (including devDependencies
#                    required at build time by Next.js / TypeScript).
# Stage 2 (builder): Copy deps, copy source, run `next build`.  The output
#                    mode "standalone" in next.config.ts produces a
#                    self-contained server bundle at .next/standalone/.
# Stage 3 (runner):  Minimal node:20-alpine image.  Copy only the standalone
#                    bundle, static assets, and public files.  No node_modules,
#                    no TypeScript compiler, no source code.
#
# Final image: ~120-160 MB (vs ~1 GB+ with node_modules included).
# ─────────────────────────────────────────────────────────────────────────────

LABEL maintainer="DentalOS Engineering <eng@dentalos.co>"
LABEL description="DentalOS Next.js 16 frontend — production runtime"
LABEL org.opencontainers.image.source="https://github.com/dentalos/dentalos"

# ── Stage 1: deps ─────────────────────────────────────────────────────────────
# Install dependencies in a dedicated stage so the cache is only invalidated
# when package-lock.json changes — not on every source code edit.
FROM node:20-alpine AS deps

# libc6-compat is required for some native Node addons on Alpine (musl libc).
# sharp (used by Next.js Image Optimization) is the most common culprit.
RUN apk add --no-cache libc6-compat

WORKDIR /app

# Copy manifests first to maximise Docker layer cache hits.
COPY package.json package-lock.json ./

# npm ci installs exactly what package-lock.json specifies — no version drift.
# --include=dev keeps devDependencies which Next.js build needs (TypeScript,
# ESLint config, Tailwind, etc.).
RUN npm ci


# ── Stage 2: builder ─────────────────────────────────────────────────────────
FROM node:20-alpine AS builder

RUN apk add --no-cache libc6-compat

WORKDIR /app

# Carry over the fully-populated node_modules from the deps stage.
COPY --from=deps /app/node_modules ./node_modules

# Copy all source files.  .dockerignore excludes .next/, node_modules, .env*.
COPY . .

# NEXT_TELEMETRY_DISABLED=1 prevents the build from phoning home to Vercel.
ENV NEXT_TELEMETRY_DISABLED=1

# Run the production build.  next.config.ts sets output: "standalone" which
# produces:
#   .next/standalone/          — self-contained Node.js server (no node_modules)
#   .next/standalone/server.js — entrypoint
#   .next/standalone/.next/   — server-side bundles
#   .next/static/             — static JS/CSS chunks (must be copied separately)
#   public/                   — static assets served directly
RUN npm run build


# ── Stage 3: runner ───────────────────────────────────────────────────────────
FROM node:20-alpine AS runner

RUN apk add --no-cache libc6-compat

WORKDIR /app

# Production Node.js mode disables development helpers (React dev warnings,
# module hot reload, etc.) and enables runtime optimisations.
ENV NODE_ENV=production

# Tell Next.js standalone server to bind to all interfaces, not just localhost.
# The external port mapping is handled by Docker / Hetzner LB.
ENV HOSTNAME="0.0.0.0"

# Disable telemetry in the production runtime as well.
ENV NEXT_TELEMETRY_DISABLED=1

# Create a non-root user to run the application.
# Running as root grants unnecessary host privileges if the container escapes.
RUN addgroup --system --gid 1001 nodejs \
    && adduser --system --uid 1001 --ingroup nodejs nextjs

# ── Copy artifacts from builder ──────────────────────────────────────────────
# 1. The standalone bundle is a self-contained Node.js server — no node_modules
#    needed at runtime.
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./

# 2. Static assets (.next/static) must live at .next/standalone/.next/static
#    so the standalone server can serve them without an external CDN.
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

# 3. Public directory (robots.txt, favicons, OG images, etc.)
COPY --from=builder --chown=nextjs:nodejs /app/public ./public

USER nextjs

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=3 \
    CMD wget -q --spider http://localhost:3000/ || exit 1

# server.js is the entrypoint generated by Next.js standalone output.
# It starts the built-in HTTP server on $PORT (defaults to 3000).
CMD ["node", "server.js"]
