# ═══════════════════════════════════════════════════════════════════════════════
# DentalOS — Production Environment Variables
#
# This is a TEMPLATE. Copy to .env on the server and fill in real values.
# The setup-server.sh script generates most secrets automatically.
#
# NEVER commit this file with real values to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Docker Compose Services ─────────────────────────────────────────────────
POSTGRES_DB=dentalos
POSTGRES_USER=dentalos
POSTGRES_PASSWORD=CHANGE_ME_postgres_password

REDIS_PASSWORD=CHANGE_ME_redis_password

RABBITMQ_USER=dentalos
RABBITMQ_PASSWORD=CHANGE_ME_rabbitmq_password
RABBITMQ_VHOST=dentalos

MINIO_ROOT_USER=dentalos_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password

# ─── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
APP_NAME=DentalOS
APP_VERSION=1.0.0
LOG_LEVEL=WARNING
ALLOWED_HOSTS=app.dentalos.co,dentalos.co

# ─── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WEB_WORKERS=2

# ─── Security ────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_secret_key_64_hex_chars
PASSWORD_PEPPER=CHANGE_ME_pepper_32_hex_chars

# ─── Database (set by docker-compose.prod.yml — do not override here) ────────
# DATABASE_URL and DATABASE_SYNC_URL are set in compose environment section.
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# ─── Redis (set by docker-compose.prod.yml) ──────────────────────────────────
# REDIS_URL is set in compose environment section.

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
# RABBITMQ_URL is set in compose environment section.
SYNC_QUEUE=false

# ─── JWT (RS256) ──────────────────────────────────────────────────────────────
# Keys are baked into the Docker image at keys/ or mounted as secrets.
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_KEY_ID=dentalos-key-1
JWT_ALGORITHM=RS256
JWT_ISSUER=dentalos-api
JWT_AUDIENCE=dentalos-api
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_BCRYPT_ROUNDS=12
LOCKOUT_THRESHOLD=5
LOCKOUT_DURATION_MINUTES=15
TENANT_SCHEMA_PREFIX=tn_

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://app.dentalos.co,https://dentalos.co
FRONTEND_URL=https://app.dentalos.co

# ─── File Storage (MinIO inside Docker network) ──────────────────────────────
# S3_ENDPOINT_URL is set in compose environment section (http://minio:9000).
S3_ACCESS_KEY=dentalos_minio
S3_SECRET_KEY=CHANGE_ME_minio_password
S3_BUCKET_NAME=dentalos-prod
S3_REGION=us-east-1

# ─── AI — Voice (STT + NLP) ──────────────────────────────────────────────────
# Production uses external APIs — no local models needed.
VOICE_STT_PROVIDER=openai
VOICE_NLP_PROVIDER=anthropic
OPENAI_API_KEY=sk-CHANGE_ME
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ─── AI — Models ─────────────────────────────────────────────────────────────
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_TREATMENT=claude-sonnet-4-5-20250514

# ─── Email (SendGrid) ────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.CHANGE_ME
SENDGRID_FROM_EMAIL=noreply@dentalos.co
SENDGRID_FROM_NAME=DentalOS

# ─── Monitoring ──────────────────────────────────────────────────────────────
SENTRY_DSN=https://CHANGE_ME@sentry.io/CHANGE_ME
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=production

PROMETHEUS_ENABLED=true
PROMETHEUS_TOKEN=CHANGE_ME_prometheus_bearer_token
