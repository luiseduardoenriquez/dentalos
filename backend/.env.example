# ═══════════════════════════════════════════════════════
# DentalOS Backend Environment Variables
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
APP_NAME=DentalOS
APP_VERSION=0.1.0
LOG_LEVEL=DEBUG
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Server ───────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ─── Database (PostgreSQL) ────────────────────────────
DATABASE_URL=postgresql+asyncpg://dentalos:dentalos_dev_password@localhost:5432/dentalos_dev
DATABASE_SYNC_URL=postgresql+psycopg://dentalos:dentalos_dev_password@localhost:5432/dentalos_dev
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# ─── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── RabbitMQ ─────────────────────────────────────────
RABBITMQ_URL=amqp://dentalos:dentalos_dev_password@localhost:5672/dentalos
SYNC_QUEUE=true

# ─── Authentication (JWT RS256) ──────────────────────
SECRET_KEY=dev-secret-key-change-in-production-immediately
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_KEY_ID=dentalos-key-1
JWT_ALGORITHM=RS256
JWT_ISSUER=dentalos-api
JWT_AUDIENCE=dentalos-api
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_BCRYPT_ROUNDS=12
PASSWORD_PEPPER=
LOCKOUT_THRESHOLD=5
LOCKOUT_DURATION_MINUTES=15
TENANT_SCHEMA_PREFIX=tn_

# ─── CORS ─────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── File Storage (MinIO / S3) ────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=dentalos_minio
S3_SECRET_KEY=dentalos_minio_password
S3_BUCKET_NAME=dentalos-dev
S3_REGION=us-east-1

# ─── Sentry (Error Tracking) ─────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_ENVIRONMENT=development
